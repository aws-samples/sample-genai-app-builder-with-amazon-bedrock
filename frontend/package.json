{
  "name": "bolt",
  "description": "StackBlitz AI Agent",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@9.4.0",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "postbuild": "cp ./package.json.lambda ./build/server/package.json",
    "build": "remix vite:build",
    "dev": "remix vite:dev",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "npm run lint -- --fix",
    "typecheck": "tsc",
    "check-bedrock": "tsx scripts/check-bedrock-sso.ts",
    "build:aws": "node generate-build-config.cjs && remix vite:build && node build.cjs",
    "deploy:aws": "pnpm run build:aws && cd ../infra && cdk deploy --require-approval never"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "^6.11.2",
